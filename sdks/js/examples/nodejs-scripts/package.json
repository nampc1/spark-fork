{
  "name": "@buildonspark/nodejs-scripts",
  "version": "0.0.136",
  "private": true,
  "description": "Example NodeJS scripts for Spark SDK",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "format:fix": "prettier . --write",
    "format": "prettier . --check",
    "test": "node --experimental-vm-modules $(yarn bin jest) --no-cache --runInBand",
    "build": "tsc",
    "types": "tsc",
    "example": "node ./scripts/run-script.mjs example",
    "get-or-create-wallet": "node ./scripts/run-script.mjs get-or-create-wallet",
    "create-invoice": "node ./scripts/run-script.mjs create-invoice",
    "deposit-bitcoin": "node ./scripts/run-script.mjs deposit-bitcoin",
    "get-all-transfers": "node ./scripts/run-script.mjs get-all-transfers",
    "get-balance": "node ./scripts/run-script.mjs get-balance",
    "get-spark-address": "node ./scripts/run-script.mjs get-spark-address",
    "get-transfers-with-time-filter": "node ./scripts/run-script.mjs get-transfers-with-time-filter",
    "pay-invoices": "node ./scripts/run-script.mjs pay-invoices",
    "send-transfer": "node ./scripts/run-script.mjs send-transfer",
    "run": "node ./scripts/run-script.mjs",
    "run:local": "cross-env NODE_ENV=development NETWORK=LOCAL node ./scripts/run-script.mjs",
    "run:k8s": "cross-env-shell NODE_ENV=development NETWORK=LOCAL MINIKUBE_IP=\"${MINIKUBE_IP:-$(minikube ip 2>/dev/null || printf 127.0.0.1)}\" node ./scripts/run-script.mjs",
    "run:mainnet": "cross-env NODE_ENV=production NETWORK=MAINNET node ./scripts/run-script.mjs",
    "run:dev": "cross-env NODE_ENV=development NETWORK=REGTEST CONFIG_FILE=../../private/config/dev-regtest-config.json node ./scripts/run-script.mjs",
    "run:dev:mainnet": "cross-env NODE_ENV=development NETWORK=MAINNET CONFIG_FILE=../../private/config/dev-mainnet-config.json node ./scripts/run-script.mjs"
  },
  "type": "module",
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.2",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@buildonspark/issuer-sdk": "0.1.30",
    "@buildonspark/spark-sdk": "0.7.12",
    "tsx": "^4.19.3"
  },
  "engines": {
    "node": ">=18"
  }
}
