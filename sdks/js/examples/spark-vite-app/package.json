{
  "name": "@buildonspark/spark-vite-app",
  "private": true,
  "version": "0.0.119",
  "type": "module",
  "scripts": {
    "start": "vite",
    "start:local": "cross-env NODE_ENV=development VITE_SPARK_NETWORK=LOCAL vite",
    "start:k8s": "cross-env-shell NODE_ENV=development VITE_SPARK_NETWORK=LOCAL MINIKUBE_IP=\"${MINIKUBE_IP:-$(minikube ip 2>/dev/null || printf 127.0.0.1)}\" vite",
    "start:mainnet": "cross-env NODE_ENV=production VITE_SPARK_NETWORK=MAINNET vite",
    "start:dev": "cross-env NODE_ENV=development VITE_SPARK_NETWORK=REGTEST CONFIG_FILE=../../private/config/dev-regtest-config.json vite",
    "start:dev:mainnet": "cross-env NODE_ENV=development VITE_SPARK_NETWORK=MAINNET CONFIG_FILE=../../private/config/dev-mainnet-config.json vite",
    "build": "tsc -b && vite build",
    "format:fix": "prettier . --write",
    "format": "prettier . --check",
    "preview": "vite preview"
  },
  "dependencies": {
    "@buildonspark/spark-sdk": "0.7.12",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "globals": "^15.15.0",
    "prettier": "^3.7.4",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  }
}
