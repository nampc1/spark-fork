{
  "name": "@buildonspark/spark-frost-bare-addon",
  "version": "0.0.11",
  "description": "Example Bare addon",
  "license": "Apache-2.0",
  "homepage": "https://github.com/buildonspark/spark",
  "exports": {
    "./package": "./package.json",
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "binding.c",
    "binding.js",
    "CMakeLists.txt",
    "CHANGELOG.md",
    "prebuilds"
  ],
  "addon": true,
  "scripts": {
    "build:native": "./build.sh",
    "test": "bare ./test.js",
    "format:fix": "prettier . --write",
    "format": "prettier . --check",
    "package:checks": "yarn publint && yarn attw --pack . && echo \"\nPackage checks passed successfully!\"",
    "prepublishOnly": "node scripts/ensure-prebuilds-present.js"
  },
  "installConfig": {
    "hoistingLimits": "dependencies"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.4",
    "@noble/curves": "^1.9.7",
    "@noble/secp256k1": "^2.3.0",
    "bare": "^1.28.4",
    "bare-make": "^1.5.1",
    "bare-node-runtime": "^1.2.0",
    "bare-runtime": "^1.28.4",
    "cmake-bare": "^1.6.5",
    "cmake-cargo": "^0.0.5",
    "cmake-npm": "^1.1.0",
    "prettier": "^3.7.4",
    "prettier-config-standard": "^7.0.0",
    "publint": "^0.3.9"
  }
}
