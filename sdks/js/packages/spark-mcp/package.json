{
  "name": "@buildonspark/spark-mcp",
  "version": "0.1.18",
  "description": "MCP server for Spark Bitcoin/Lightning wallet operations",
  "license": "Apache-2.0",
  "type": "module",
  "bin": "./dist/index.js",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn tsc --noEmit -p tsconfig.build.json && rm -rf dist && tsdown",
    "clean": "rm -rf dist",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "test-cmd": "node --experimental-vm-modules $(yarn bin jest) --no-cache --runInBand --detectOpenHandles --forceExit",
    "test": "yarn test-cmd 'src/tests/**/*.test.ts'",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@buildonspark/spark-sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.2",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "ts-jest": "^29.2.5",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
