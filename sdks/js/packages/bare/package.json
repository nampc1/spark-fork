{
  "name": "@buildonspark/bare",
  "version": "0.0.67",
  "author": "",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "type": "module",
  "description": "Spark SDK for Bare runtime",
  "keywords": [
    "bitcoin",
    "spark",
    "bare",
    "pear"
  ],
  "homepage": "https://github.com/buildonspark/spark",
  "files": [
    "dist",
    "src",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": {
        "default": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "require": {
        "default": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    },
    "./package": "./package.json"
  },
  "scripts": {
    "build": "yarn tsc && rm -rf dist && tsdown",
    "build:watch": "yarn build --watch --clean=false",
    "clean": "rm -rf dist",
    "circular-deps": "madge --circular --extensions ts,tsx src",
    "dev": "yarn build -- --watch",
    "depcheck": "depcheck --ignores='bare-*,@noble/hashes'",
    "format:fix": "prettier . --write",
    "format": "prettier . --check",
    "lint:fix": "eslint --fix .",
    "lint:fix:continue": "eslint --fix . || exit 0",
    "lint:watch": "esw ./src -w --ext .ts,.tsx,.js --color",
    "lint": "eslint .",
    "package:checks": "yarn depcheck && yarn publint && yarn attw --pack . && echo \"\nPackage checks passed successfully!\"",
    "postversion": "yarn build",
    "test-cmd": "node --experimental-vm-modules $(yarn bin jest) --no-cache --runInBand --detectOpenHandles --forceExit",
    "test": "echo \"Skipping for now\"",
    "test:integration": "bare tests/run-integration-tests.js",
    "test:integration:ssp": "bare tests/run-ssp-integration-tests.js",
    "types:watch": "tsc-absolute --watch",
    "types": "tsc"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.4",
    "@lightsparkdev/eslint-config": "^0.0.1",
    "@noble/hashes": "^1.7.0",
    "bare": "^1.28.4",
    "bare-runtime": "^1.28.4",
    "depcheck": "^1.4.7",
    "eslint": "^9.25.0",
    "eslint-watch": "^8.0.0",
    "madge": "^8.0.0",
    "prettier": "^3.7.4",
    "publint": "^0.3.9",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@buildonspark/spark-frost-bare-addon": "0.0.11",
    "@buildonspark/spark-sdk": "0.7.17",
    "bare-node-runtime": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "madge": {
    "detectiveOptions": {
      "ts": {
        "skipTypeImports": true
      },
      "tsx": {
        "skipTypeImports": true
      }
    }
  }
}
