{
  "name": "js",
  "description": "Spark JS Projects",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build-no-cache": "yarn build --force",
    "build": "turbo run build",
    "build:sdk": "turbo run build --filter='./packages/*-sdk'",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:packages:watch": "yarn turbo watch build --filter='./packages/*'",
    "checks": "yarn deps:check && turbo run build format circular-deps package:checks test lint",
    "postinstall": "./postinstall.sh",
    "circular-deps": "turbo run circular-deps",
    "clean": "turbo run clean",
    "clean-all": "./clean-all.sh",
    "clean-resolve": "echo \"Use only as a last resort when clean-all fails to resolve an issue. In general yarn.lock should only be modified when dependencies explicitly change.\" && yarn clean-all && rm yarn.lock && yarn",
    "deps:check": "manypkg check",
    "deps:fix": "manypkg fix",
    "format": "turbo run format",
    "format:fix": "turbo run format:fix",
    "generate:proto:check": "yarn workspace @buildonspark/spark-sdk generate:proto:check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "release": "yarn build:packages && changeset publish",
    "package:checks": "turbo run package:checks",
    "start": "turbo run start",
    "test": "turbo run test",
    "test:all": "yarn deps:check && turbo run test test:integration test:integration:ssp",
    "test:integration": "yarn deps:check && turbo run test:integration",
    "test:integration:ssp": "yarn deps:check && turbo run test:integration:ssp",
    "types": "turbo run types"
  },
  "workspaces": [
    "apps/*",
    "examples/*",
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@manypkg/cli": "^0.24.0",
    "@octokit/auth-action": "^4.0.1",
    "bare-make": "^1.5.1",
    "cmake-bare": "^1.6.5",
    "cmake-fetch": "^1.4.7",
    "detox": "20.39.0",
    "octokit": "^4.0.2",
    "ts-prune": "^0.10.3",
    "turbo": "^2.4.4"
  },
  "packageManager": "yarn@4.13.0"
}
